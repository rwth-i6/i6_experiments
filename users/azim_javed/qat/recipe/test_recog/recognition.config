[*]
encoding = UTF-8
log.channel = rasr.log

[lib-rasr.channels.output-channel]
file = test.txt

[lib-rasr.lexicon]
file                    = /work/asr4/berger/rasr_dev/label_scorer/setup/dependencies/lexicon.xml
normalize-pronunciation = no

[lib-rasr.search-algorithm]
type              = lexiconfree-timesync-beam-search
blank-label-index = 184
collapse-repeated-labels  = yes
max-beam-size = 1

[lib-rasr.label-scorer]
type         = pytorch-ctc
transition-preset = ctc
test-parameter = Hello World
